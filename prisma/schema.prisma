// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════
// TABLE : users
// ═══════════════════════════════════════
model User {
  id             Int       @id @default(autoincrement())
  wallet_address String    @unique @db.VarChar(42)
  username       String    @db.VarChar(100)
  email          String?   @unique @db.VarChar(255)
  avatar_url     String?   @db.Text
  role           Role      @default(contributor)
  bio            String?   @db.Text
  last_login_at  DateTime?
  is_visible     Boolean   @default(true)
  is_active      Boolean   @default(true)
  created_by     Int?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  // Relations
  campaigns_created    Campaign[]              @relation("CampaignCreator")
  contributions_made   Contribution[]          @relation("ContributorUser")
  notifications        Notification[]
  transactions         BlockchainTransaction[] @relation("TransactionUser")
  creator_ref          User?                   @relation("UserCreatedBy", fields: [created_by], references: [id])
  created_users        User[]                  @relation("UserCreatedBy")

  @@map("users")
}

enum Role {
  visitor
  contributor
  creator
  admin
}

// ═══════════════════════════════════════
// TABLE : categories
// ═══════════════════════════════════════
model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(100)
  slug        String    @unique @db.VarChar(100)
  description String?   @db.Text
  icon_url    String?   @db.Text
  is_visible  Boolean   @default(true)
  is_active   Boolean   @default(true)
  created_by  Int?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  campaigns   Campaign[]

  @@map("categories")
}

// ═══════════════════════════════════════
// TABLE : campaigns
// ═══════════════════════════════════════
model Campaign {
  id               Int            @id @default(autoincrement())
  title            String         @db.VarChar(255)
  description      String         @db.Text
  goal_amount      Decimal        @db.Decimal(18, 8)
  current_amount   Decimal        @default(0) @db.Decimal(18, 8)
  deadline         DateTime
  status           CampaignStatus @default(draft)
  image_url        String?        @db.Text
  contract_address String?        @db.VarChar(42)
  creator_id       Int
  category_id      Int?
  is_visible       Boolean        @default(true)
  is_active        Boolean        @default(true)
  created_by       Int
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt

  // Relations
  creator       User                    @relation("CampaignCreator", fields: [creator_id], references: [id])
  category      Category?               @relation(fields: [category_id], references: [id])
  contributions Contribution[]
  transactions  BlockchainTransaction[]

  @@map("campaigns")
}

enum CampaignStatus {
  draft
  active
  succeeded
  failed
  cancelled
  closed
}

// ═══════════════════════════════════════
// TABLE : contributions
// ═══════════════════════════════════════
model Contribution {
  id             Int                @id @default(autoincrement())
  campaign_id    Int
  contributor_id Int
  amount         Decimal            @db.Decimal(18, 8)
  tx_hash        String             @unique @db.VarChar(66)
  status         ContributionStatus @default(pending)
  block_number   BigInt?
  contributed_at DateTime           @default(now())
  is_visible     Boolean            @default(true)
  is_active      Boolean            @default(true)
  created_by     Int
  created_at     DateTime           @default(now())
  updated_at     DateTime           @updatedAt

  // Relations
  campaign    Campaign @relation(fields: [campaign_id], references: [id])
  contributor User     @relation("ContributorUser", fields: [contributor_id], references: [id])

  @@map("contributions")
}

enum ContributionStatus {
  pending
  confirmed
  refunded
  failed
}

// ═══════════════════════════════════════
// TABLE : blockchain_transactions
// ═══════════════════════════════════════
model BlockchainTransaction {
  id           Int               @id @default(autoincrement())
  tx_hash      String            @unique @db.VarChar(66)
  type         TransactionType
  from_address String            @db.VarChar(42)
  to_address   String            @db.VarChar(42)
  amount       Decimal           @default(0) @db.Decimal(18, 8)
  gas_used     BigInt?
  block_number BigInt?
  status       TransactionStatus @default(pending)
  campaign_id  Int?
  user_id      Int?
  is_visible   Boolean           @default(true)
  is_active    Boolean           @default(true)
  created_by   Int?
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt

  // Relations
  campaign Campaign? @relation(fields: [campaign_id], references: [id])
  user     User?     @relation("TransactionUser", fields: [user_id], references: [id])

  @@map("blockchain_transactions")
}

enum TransactionType {
  contribution
  withdrawal
  refund
  deploy
}

enum TransactionStatus {
  pending
  success
  failed
}

// ═══════════════════════════════════════
// TABLE : notifications
// ═══════════════════════════════════════
model Notification {
  id         Int              @id @default(autoincrement())
  user_id    Int
  type       NotificationType
  title      String           @db.VarChar(255)
  message    String           @db.Text
  is_read    Boolean          @default(false)
  link       String?          @db.Text
  is_visible Boolean          @default(true)
  is_active  Boolean          @default(true)
  created_by Int?
  created_at DateTime         @default(now())
  updated_at DateTime         @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@map("notifications")
}

enum NotificationType {
  contribution
  goal_reached
  refund
  campaign_end
  system
}
